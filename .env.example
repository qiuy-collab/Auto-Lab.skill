# ============================================================
# Image generation API config (required)
# ============================================================
# The image script reads this file from repo root as .env
# It calls: ${BASEURL}/v1/images/generations
# Recommended upstream model: gpt-image-2

# Single upstream mode (backward compatible)
BASEURL:https://your-image-api-base.example.com
APIKEY:replace-with-real-key

# ============================================================
# Multi-upstream mode (optional, for parallel generation)
# ============================================================
# Uncomment and fill to enable multi-upstream parallel generation.
# When enabled, each upstream handles 1/N of the images via sharding.
#
# Comma-separated format (auto-detected):
# BASEURLS:https://api1.example.com,https://api2.example.com
# APIKEYS:sk-key1,sk-key2
#
# Or numbered format:
# BASEURL1:https://api1.example.com
# APIKEY1:sk-key1
# BASEURL2:https://api2.example.com
# APIKEY2:sk-key2

# ============================================================
# Prompt validation agent (recommended)
# ============================================================
# Validates prompt_config.json for consistency before image generation.
# Uses a separate AI model for independent quality checking.
AGNES_BASEURL:https://your-validator-api.example.com
AGNES_APIKEY:replace-with-real-key
AGNES_MODEL:agnes-2.0-flash
